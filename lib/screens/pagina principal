import 'package:flutter/material.dart';
import '../services/name_service.dart';
import '../widgets/name_card.dart';
import 'favorites_page.dart';

class HomePage extends StatefulWidget {
  const HomePage({super.key});

  @override
  State<HomePage> createState() => _HomePageState();
}

class _HomePageState extends State<HomePage> {

  final List<String> firstWords = [
    "Blue", "Fast", "Smart", "Bright", "Next", "Light", "Sky", "Neo"
  ];

  final List<String> secondWords = [
    "Core", "Flow", "Tech", "Zone", "Stream", "Nova", "Drive", "Wave"
  ];

  final List<String> allCombinations = [];
  final List<String> favorites = [];

  int currentIndex = 0;
  String currentWord = "";

  @override
  void initState() {
    super.initState();
    generateAllCombinations();
    getNextWord();
  }

  // 🔥 Generar TODAS las combinaciones
  void generateAllCombinations() {
    for (var first in firstWords) {
      for (var second in secondWords) {
        allCombinations.add(first + second);
      }
    }
    allCombinations.shuffle(Random());
  }

  // 🔄 Obtener siguiente palabra SIN repetir
  void getNextWord() {
    setState(() {
      if (currentIndex < allCombinations.length) {
        currentWord = allCombinations[currentIndex];
        currentIndex++;
      } else {
        currentWord = "No more names 😢";
      }
    });
  }

  // ❤️ Favoritos
  void toggleFavorite() {
    setState(() {
      if (favorites.contains(currentWord)) {
        favorites.remove(currentWord);
      } else {
        favorites.add(currentWord);
      }
    });
  }

  // 📍 Navegación
  void goToFavorites() {
    Navigator.push(
      context,
      MaterialPageRoute(
        builder: (context) => FavoritesPage(favorites: favorites),
      ),
    );
  }

  @override
  Widget build(BuildContext context) {

    bool isFavorite = favorites.contains(currentWord);

    return Scaffold(
      appBar: AppBar(
        title: const Text("Name Generator PRO"),
        centerTitle: true,
        actions: [
          IconButton(
            icon: const Icon(Icons.favorite),
            onPressed: goToFavorites,
          )
        ],
      ),

      body: Center(
        child: Padding(
          padding: const EdgeInsets.all(20),

          child: Column(
            mainAxisAlignment: MainAxisAlignment.center,
            children: [

              // TARJETA
              Card(
                elevation: 8,
                shape: RoundedRectangleBorder(
                  borderRadius: BorderRadius.circular(20),
                ),
                child: Padding(
                  padding: const EdgeInsets.symmetric(
                      vertical: 30, horizontal: 40),
                  child: Text(
                    currentWord,
                    style: const TextStyle(
                      fontSize: 32,
                      fontWeight: FontWeight.bold,
                      color: Colors.indigo,
                    ),
                  ),
                ),
              ),

              const SizedBox(height: 30),

              // BOTONES
              Row(
                mainAxisAlignment: MainAxisAlignment.center,
                children: [

                  ElevatedButton.icon(
                    onPressed: currentWord == "No more names 😢"
                        ? null
                        : toggleFavorite,
                    icon: Icon(
                      isFavorite
                          ? Icons.favorite
                          : Icons.favorite_border,
                    ),
                    label: const Text("Favorite"),
                  ),

                  const SizedBox(width: 20),

                  ElevatedButton(
                    onPressed: getNextWord,
                    child: const Text("Next"),
                  ),
                ],
              )
            ],
          ),
        ),
      ),
    );
  }
}

          ),
        ),
      ),
    );
  }
}
